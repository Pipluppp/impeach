{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/public-session.schema.json",
  "title": "Synchronized Senate journal public session",
  "type": "object",
  "required": ["schema_version", "session", "sources", "processing", "outline", "pages"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.1.0"},
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "date", "journal_number", "title"],
      "properties": {
        "id": {"type": "string"}, "date": {"type": "string", "format": "date"},
        "journal_number": {"type": "integer", "minimum": 1}, "title": {"type": "string"}
      }
    },
    "sources": {
      "type": "object", "additionalProperties": false, "required": ["journal", "video"],
      "properties": {
        "journal": {"$ref": "#/$defs/journalSource"},
        "video": {"$ref": "#/$defs/videoSource"}
      }
    },
    "processing": {
      "type": "object", "additionalProperties": false,
      "required": ["source_revision", "parser", "alignment_summary", "alignment_policy"],
      "properties": {
        "source_revision": {"type": "integer", "minimum": 1},
        "parser": {"type": "string"},
        "aligner": {"type": ["string", "null"]},
        "alignment_summary": {
          "type": "object", "additionalProperties": false,
          "required": ["total_blocks", "timed_blocks", "coverage", "needs_review", "manual_reviewed", "unresolved_conflicts"],
          "properties": {
            "total_blocks": {"type": "integer", "minimum": 1},
            "timed_blocks": {"type": "integer", "minimum": 0},
            "coverage": {"type": "number", "minimum": 0, "maximum": 1},
            "needs_review": {"type": "integer", "minimum": 0},
            "manual_reviewed": {"type": "integer", "minimum": 0},
            "unresolved_conflicts": {"type": "integer", "minimum": 0}
          }
        },
        "alignment_policy": {"type": "string"}
      }
    },
    "outline": {"type": "array", "items": {"$ref": "#/$defs/outlineItem"}},
    "pages": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/page"}}
  },
  "$defs": {
    "journalSource": {
      "type": "object", "additionalProperties": false,
      "required": ["url", "listing_url", "retrieved_at", "sha256", "page_count"],
      "properties": {
        "url": {"type": "string", "format": "uri"}, "listing_url": {"type": "string", "format": "uri"},
        "retrieved_at": {"type": "string", "format": "date-time"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "page_count": {"type": "integer", "minimum": 1}
      }
    },
    "videoSource": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "url", "playlist_id", "channel", "duration_seconds"],
      "properties": {
        "id": {"type": "string"}, "url": {"type": "string", "format": "uri"},
        "playlist_id": {"type": "string"}, "channel": {"type": "string"},
        "duration_seconds": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "timing": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["start", "end", "time_domain", "precision", "confidence", "review_state"],
      "properties": {
        "start": {"type": "number", "minimum": 0}, "end": {"type": "number", "minimum": 0},
        "time_domain": {"const": "session_video"}, "precision": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "review_state": {"type": "string"}
      }
    },
    "timeReference": {
      "type": "object", "required": ["time_domain"],
      "anyOf": [{"required": ["time_seconds"]}, {"required": ["time_seconds_since_midnight"]}],
      "properties": {
        "time_domain": {"type": "string"}, "time_seconds": {"type": "number", "minimum": 0},
        "time_seconds_since_midnight": {"type": "number", "minimum": 0},
        "display": {"type": "string"}, "exhibit_id": {"type": "string"}
      },
      "additionalProperties": true
    },
    "block": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "sequence", "kind", "text", "timing"],
      "properties": {
        "id": {"type": "string"}, "sequence": {"type": "integer", "minimum": 1},
        "kind": {"type": "string"}, "text": {"type": "string"}, "speaker": {"type": ["string", "null"]},
        "section_id": {"type": ["string", "null"]}, "role": {"type": ["string", "null"]},
        "timing": {"$ref": "#/$defs/timing"},
        "source_time_references": {"type": "array", "items": {"$ref": "#/$defs/timeReference"}}
      }
    },
    "page": {
      "type": "object", "additionalProperties": false, "required": ["number", "blocks"],
      "properties": {"number": {"type": "integer", "minimum": 1}, "blocks": {"type": "array", "items": {"$ref": "#/$defs/block"}}}
    },
    "outlineItem": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "title", "first_block_id", "page", "timing"],
      "properties": {
        "id": {"type": "string"}, "title": {"type": "string"}, "first_block_id": {"type": "string"},
        "page": {"type": "integer", "minimum": 1}, "timing": {"$ref": "#/$defs/timing"}
      }
    }
  }
}
