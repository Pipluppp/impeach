{
  "name": "senate-synchronized-journal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "doctor": "npx --yes react-doctor@0.7.8 --no-telemetry",
    "check": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "@eslint/js": "9.39.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vitest": "4.1.10",
    "wrangler": "^4.111.0"
  }
}
